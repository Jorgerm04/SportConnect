<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox styleClass="main-bg" stylesheets="@../base.css, @home.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.sportconnect.controllers.HomeController">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets bottom="15.0" left="40.0" right="40.0" top="15.0" />
            </padding>
            <children>
                <VBox spacing="-10">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 24;" text="Sp" />
                            <Text fill="#2563eb" style="-fx-font-weight: 900; -fx-font-size: 24;" text="o" />
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 24;" text="rt" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" translateX="12">
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 22;" text="C" />
                            <Text fill="#2563eb" style="-fx-font-weight: 900; -fx-font-size: 22;" text="o" />
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 22;" text="nnect" />
                        </HBox>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Label fx:id="lblUserName" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="Usuario" />
                        <Button onAction="#handleLogout" styleClass="logout-btn">
                            <graphic>
                                <FontIcon iconColor="#9F9F9F" iconLiteral="fas-sign-out-alt" iconSize="22" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="35.0">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" styleClass="welcome-banner">
                            <padding>
                                <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
                            </padding>
                            <children>
                                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="banner-title" text="¿Listo para jugar?" />
                                        <Label styleClass="banner-subtitle" text="Reserva tu pistas en solo unos pasos" />
                                    </children>
                                </VBox>
                                <Button fx:id="btnNuevaReserva" onAction="#handleNuevaReserva" styleClass="banner-add-button" text="+  Nueva Reserva" />
                            </children>
                        </HBox>

                        <VBox spacing="20.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <children>
                                        <FontIcon iconColor="#2563eb" iconLiteral="fas-calendar-minus" iconSize="20" />
                                        <Label styleClass="section-title" text="Próximas reservas" />
                                    </children>
                                </HBox>
                                <VBox fx:id="containerProximas" spacing="15.0" />
                            </children>
                        </VBox>

                        <VBox spacing="20.0">
                            <children>
                                <Label styleClass="section-title" text="Historial" />
                                <VBox fx:id="containerHistorial" spacing="15.0" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>