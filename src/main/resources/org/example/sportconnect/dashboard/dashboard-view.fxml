<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox styleClass="main-bg" stylesheets="@../base.css, @dashboard.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.sportconnect.controllers.DashboardController">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets bottom="15.0" left="40.0" right="40.0" top="15.0" />
            </padding>
            <children>
                <VBox spacing="-10">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 24;" text="Sp" />
                            <Text fill="#2563eb" style="-fx-font-weight: 900; -fx-font-size: 24;" text="o" />
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 24;" text="rt" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" translateX="12">
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 22;" text="C" />
                            <Text fill="#2563eb" style="-fx-font-weight: 900; -fx-font-size: 22;" text="o" />
                            <Text fill="WHITE" style="-fx-font-weight: 900; -fx-font-size: 22;" text="nnect" />
                        </HBox>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Label fx:id="lblUserName" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="Usuario" />
                        <Button onAction="#handleLogout" styleClass="logout-btn">
                            <graphic>
                                <FontIcon iconColor="#9F9F9F" iconLiteral="fas-sign-out-alt" iconSize="22" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <VBox spacing="25.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="40.0" right="40.0" top="15.0" />
            </padding>
            <children>

                <GridPane hgap="20.0" vgap="20.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14;" text="Reservas activas" textFill="#94a3b8" />
                                    <Label fx:id="lblTotalReservas" style="-fx-font-size: 36; -fx-font-weight: bold;" text="0" textFill="WHITE" />
                                </VBox>
                                <StackPane styleClass="icon-container-blue">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-calendar-check" iconSize="24" />
                                </StackPane>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14;" text="Usuarios" textFill="#94a3b8" />
                                    <Label fx:id="lblTotalUsuarios" style="-fx-font-size: 36; -fx-font-weight: bold;" text="0" textFill="WHITE" />
                                </VBox>
                                <StackPane styleClass="icon-container-blue">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-users" iconSize="24" />
                                </StackPane>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14;" text="Pistas" textFill="#94a3b8" />
                                    <Label fx:id="lblTotalPistas" style="-fx-font-size: 36; -fx-font-weight: bold;" text="0" textFill="WHITE" />
                                </VBox>
                                <StackPane styleClass="icon-container-blue">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-th-large" iconSize="24" />
                                </StackPane>
                            </HBox>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 14;" text="Ingresos" textFill="#94a3b8" />
                                    <Label fx:id="lblTotalIngresos" style="-fx-font-size: 36; -fx-font-weight: bold;" text="0€" textFill="WHITE" />
                                </VBox>
                                <StackPane styleClass="icon-container-blue">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fas-money-bill-wave" iconSize="24" />
                                </StackPane>
                            </HBox>
                        </VBox>
                    </children>
                </GridPane>

                <VBox spacing="0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                    <children>
                        <HBox alignment="BOTTOM_LEFT" styleClass="tab-header-container">
                            <children>
                                <HBox styleClass="tab-container">
                                    <children>
                                        <Button fx:id="btnTabReservas" onAction="#handleTabChange" styleClass="tab-button, active" text="Reservas" />
                                        <Button fx:id="btnTabDeportes" onAction="#handleTabChange" styleClass="tab-button" text="Deportes" />
                                        <Button fx:id="btnTabPistas" onAction="#handleTabChange" styleClass="tab-button" text="Pistas" />
                                        <Button fx:id="btnTabUsuarios" onAction="#handleTabChange" styleClass="tab-button" text="Usuarios" />
                                    </children>
                                </HBox>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button fx:id="btnAddAction" onAction="#handleAdd" styleClass="add-button" text="Nuevo Registro">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-plus" iconColor="WHITE" iconSize="14" />
                                    </graphic>
                                    <HBox.margin>
                                        <Insets bottom="10.0" />
                                    </HBox.margin>
                                </Button>
                            </children>
                        </HBox>

                        <VBox spacing="0" VBox.vgrow="ALWAYS">
                            <children>
                                <StackPane VBox.vgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="genericTable" styleClass="custom-table" visible="true">
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                            </columnResizePolicy>
                                        </TableView>

                                        <ScrollPane fx:id="scrollDeportes" fitToWidth="true" styleClass="scroll-deportes" visible="false">
                                            <content>
                                                <TilePane fx:id="tileDeportes" hgap="20.0" prefColumns="4" vgap="20.0">
                                                    <padding>
                                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                                    </padding>
                                                </TilePane>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </StackPane>

                                <HBox alignment="CENTER">
                                    <Pagination fx:id="pagination" maxPageIndicatorCount="5" styleClass="custom-pagination" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </children>
</VBox>